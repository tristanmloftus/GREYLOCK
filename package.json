{
  "name": "greylock",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Private financial operating dashboard for PCC. Localhost-only, passkey-only, three users.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "dev": "next dev --experimental-https --experimental-https-cert ./certs/localhost.pem --experimental-https-key ./certs/localhost-key.pem",
    "build": "next build",
    "start": "next start",
    "sync": "tsx scripts/sync.ts",
    "setup:certs": "mkdir -p certs && mkcert -cert-file certs/localhost.pem -key-file certs/localhost-key.pem localhost 127.0.0.1 ::1",
    "admin:enroll": "tsx scripts/admin-enroll.ts",
    "admin:revoke": "tsx scripts/admin-revoke.ts",
    "admin:revoke-all": "tsx scripts/admin-revoke-all.ts",
    "admin:rotate-master": "tsx scripts/admin-rotate-master.ts",
    "admin:audit-verify": "tsx scripts/admin-audit-verify.ts",
    "lint": "next lint && eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:deps": "pnpm audit --prod --audit-level=high",
    "prepare": "husky || true"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@prisma/client": "^6.1.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "iron-session": "^8.0.4",
    "plaid": "^27.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@playwright/test": "^1.49.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-security": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "prettier": "^3.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
