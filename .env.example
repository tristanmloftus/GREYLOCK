# =============================================================================
# Greylock — environment template
# =============================================================================
# Copy to `.env` and fill in. NEVER commit `.env`.
# Every variable here MUST be set before `pnpm dev` will start.
# =============================================================================

# --- App ---
NODE_ENV=development
APP_URL=https://localhost:3000
APP_PORT=3000

# --- Allowlist (hard cap: 3 emails) -----------------------------------------
# Only these emails may complete passkey registration.
# Format: comma-separated, lowercase, no spaces.
# NOTE: cade-placeholder@greylock.invalid is a PLACEHOLDER — replace before
# Cade can enroll. Real Cade email TBD.
ALLOWED_EMAILS=rory.patrick.loftus@gmail.com,tristan.m.loftus@gmail.com,cade-placeholder@greylock.invalid

# --- Owner identity ---------------------------------------------------------
# Used by admin CLI to gate `/admin` routes (audit viewer, passkey enroll).
OWNER_EMAIL=rory.patrick.loftus@gmail.com

# --- WebAuthn / Passkey -----------------------------------------------------
# RP_ID must be a registrable domain — for localhost use exactly "localhost".
# RP_ORIGIN must match the URL the browser loads (https + port).
WEBAUTHN_RP_NAME=Greylock
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=https://localhost:3000

# --- Session (iron-session) -------------------------------------------------
# 32+ random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
SESSION_COOKIE_NAME=greylock_session
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=8

# --- Database (SQLCipher-encrypted SQLite) ----------------------------------
# Prisma URL points at an encrypted file. The DB encryption key is derived at
# runtime from the master passphrase (fetched from macOS Keychain) — it is
# NOT stored in this file.
DATABASE_URL=file:./prisma/greylock.db

# --- Master passphrase (Keychain-backed) ------------------------------------
# Greylock fetches the master passphrase via:
#   security find-generic-password -s greylock-master -a $USER -w
# Set it once with:
#   security add-generic-password -s greylock-master -a $USER -w '<passphrase>' -U
# If KEYCHAIN_FALLBACK_TTY=true, missing Keychain item triggers a TTY prompt.
KEYCHAIN_SERVICE_NAME=greylock-master
KEYCHAIN_FALLBACK_TTY=true

# --- Crypto pepper ---------------------------------------------------------
# Per-deployment pepper mixed into KDF salts. 32+ random bytes, base64.
# Compromise of this alone does NOT unlock data — but rotation invalidates
# any stored salts that depend on it.
CRYPTO_PEPPER=

# --- Plaid -----------------------------------------------------------------
# Sandbox by default. Set PLAID_ENV=production only when going live.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Comma-separated. development/sandbox accept these defaults.
PLAID_PRODUCTS=transactions,auth,identity
PLAID_COUNTRY_CODES=US

# --- Sync loop -------------------------------------------------------------
# Interval for the background `pnpm sync` process (minutes).
SYNC_INTERVAL_MINUTES=15

# --- Rate limiting --------------------------------------------------------
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# --- TLS (mkcert) ---------------------------------------------------------
# Paths relative to repo root. Generated by `pnpm setup:certs`.
TLS_CERT_PATH=./certs/localhost.pem
TLS_KEY_PATH=./certs/localhost-key.pem
